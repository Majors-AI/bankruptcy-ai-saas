                        }
                      </div>
                      <div className="min-w-0">
                        <p className="text-xs text-slate-200 font-semibold leading-snug">
                          Complete attorney fee payment
                        </p>
                        <p className="text-xs text-slate-500 mt-0.5">
                          ${remaining.toLocaleString()} remaining · due {CASE_DATA.payoffDate}
                        </p>
                      </div>
                    </div>
                    <div className="flex items-start gap-2">
                      <div className="w-4 h-4 rounded-full flex-shrink-0 mt-0.5 flex items-center justify-center bg-slate-700">
                        <Clock className="w-3 h-3 text-slate-500" />
                      </div>
                      <div className="min-w-0">
                        <p className="text-xs text-slate-400 font-semibold leading-snug">
                          Upload required documents
                        </p>
                        <p className="text-xs text-slate-600 mt-0.5">
                          Unlocks within 60 days of payoff
                          {daysToPayoff > 0 ? ` · ${daysToPayoff} days away` : ""}
                        </p>
                      </div>
                    </div>
                  </div>
                </div>

                {/* What's blocking you */}
                {(stepsComplete < FORM_STEPS.length || daysToPayoff > 0) && (
                  <div className="bg-red-500/8 border border-red-500/20 rounded-xl px-4 py-3 mb-3">
                    <div className="flex items-start gap-2">
                      <AlertTriangle className="w-3.5 h-3.5 text-red-400 flex-shrink-0 mt-0.5" />
                      <div>
                        <p className="text-xs font-bold uppercase tracking-widest text-red-400 mb-1">What's Blocking Your Filing</p>
                        <ul className="space-y-1">
                          {stepsComplete < FORM_STEPS.length && (
                            <li className="text-xs text-slate-300 leading-snug">
                              Questionnaire incomplete — {FORM_STEPS.length - stepsComplete} step{FORM_STEPS.length - stepsComplete !== 1 ? "s" : ""} remaining
                            </li>
                          )}
                          {daysToPayoff > 0 && (
                            <li className="text-xs text-slate-300 leading-snug">
                              Attorney fees not paid in full — ${remaining.toLocaleString()} due
                            </li>
                          )}
                          {daysToPayoff > 60 && (
                            <li className="text-xs text-slate-300 leading-snug">
                              Document upload not yet available ({daysToPayoff} days to payoff)
                            </li>
                          )}
                        </ul>
                      </div>
                    </div>
                  </div>
                )}

                {/* CTA */}
                <button
                  onClick={handleContinueClick}
                  className="w-full flex items-center justify-center gap-2 bg-amber-400 hover:bg-amber-300 text-slate-950 font-bold px-4 py-2.5 rounded-xl text-xs transition-colors uppercase tracking-wide"
                >
                  Continue Questionnaire
                  <ArrowRight className="w-3.5 h-3.5" />
                </button>
              </div>

              {/* ── Roadmap header ── */}
              <div className="px-5 py-3 border-b border-slate-800">
                <p className="text-xs font-bold uppercase tracking-widest text-slate-400 mb-0.5">Case Roadmap</p>
                <p className="text-white font-semibold text-sm" style={{ fontFamily: "'Georgia', serif" }}>
                  Chapter {CASE_DATA.chapter} · {STAGES.filter((s) => s.status === "complete").length} of {STAGES.length} stages done
                </p>
              </div>
              <nav className="px-3 py-3">
                {STAGES.map((stage, idx) => {
                  const isSelected = sidebarStageId === stage.id;
                  const isCurrent = CASE_DATA.currentStage === stage.id;
                  const isComplete = stage.status === "complete";
                  const isActive = stage.status === "active";
                  const isLast = idx === STAGES.length - 1;

                  return (
                    <div key={stage.id} className="flex gap-3">
                      <div className="flex flex-col items-center flex-shrink-0 pt-2.5">
                        <div className={`w-7 h-7 rounded-full border-2 flex items-center justify-center flex-shrink-0 transition-all ${
                          isComplete ? "bg-green-500 border-green-500 text-white" :
                          isActive   ? "bg-amber-400 border-amber-400 text-slate-950" :
                                       "border-slate-700 text-slate-600 bg-slate-900"
                        }`}>
                          {isComplete
                            ? <CheckCircle2 className="w-4 h-4 text-white" />
                            : isActive
                              ? <span className="w-2 h-2 bg-slate-950 rounded-full block" />
                              : <span className="text-xs font-bold">{stage.id}</span>
                          }
                        </div>
                        {!isLast && (
                          <div className={`w-px flex-1 my-1 ${isComplete ? "bg-green-500/40" : "bg-slate-800"}`} style={{ minHeight: 20 }} />
                        )}
                      </div>

                      <button
                        onClick={() => setSidebarStageId(isSelected ? null : stage.id)}
                        className={`flex-1 text-left px-3 py-2.5 rounded-xl mb-0.5 transition-all ${
                          isSelected
                            ? "bg-slate-800 border border-slate-700"
                            : "hover:bg-slate-800/60 border border-transparent"
                        }`}
                      >
                        <div className="flex items-center gap-1.5 mb-0.5">
                          <p className={`text-xs font-bold leading-none ${
                            isComplete ? "text-green-400" :
                            isActive   ? "text-amber-400" :
                                         "text-slate-500"
                          }`}>
                            Stage {stage.id}
                          </p>
                          {isCurrent && (
                            <span className="text-xs bg-amber-400/15 text-amber-400 border border-amber-400/30 px-1.5 py-px rounded-full leading-none font-semibold">
                              Current
                            </span>
                          )}
                        </div>
                        <p className={`text-xs leading-snug font-medium ${
                          isComplete ? "text-slate-400" :
                          isActive   ? "text-slate-200" :
                                       "text-slate-600"
                        }`}>
                          {stage.label}
                        </p>
                        <p className="text-xs text-slate-600 mt-0.5">{stage.date}</p>
                      </button>
                    </div>
                  );
                })}
              </nav>
            </div>
          </div>

          {/* ── Right: Stage detail (non-Stage-2) or placeholder ── */}
          <div className="lg:col-span-2 space-y-5">

            {sidebarStage && sidebarStage.id !== 2 ? (
              /* Detail panel for stages other than Stage 2 */
              <div className="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
                <div className={`px-6 py-5 border-b border-slate-800 ${sidebarStage.status === "active" ? "bg-amber-400/5" : ""}`}>
                  <div className="flex items-center justify-between gap-3">
                    <div>
                      <div className="flex items-center gap-2 mb-2">
                        <span className={`inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wide px-2.5 py-1 rounded-full border ${
                          sidebarStage.status === "complete" ? "text-green-400 bg-green-400/10 border-green-400/30" :
                          sidebarStage.status === "active"   ? "text-amber-400 bg-amber-400/10 border-amber-400/30" :
                                                               "text-slate-500 bg-slate-800 border-slate-700"
                        }`}>
                          {sidebarStage.status === "complete"
                            ? <><CheckCircle2 className="w-3 h-3" /> Completed</>
                            : sidebarStage.status === "active"
                              ? <><Clock className="w-3 h-3" /> In Progress</>
                              : <><Circle className="w-3 h-3" /> Upcoming</>
                          }
                        </span>
                        <span className="text-xs text-slate-500">{sidebarStage.date}</span>
                      </div>
                      <h2 className="text-xl font-bold text-white" style={{ fontFamily: "'Georgia', serif" }}>
                        Stage {sidebarStage.id} — {sidebarStage.label}
                      </h2>
                      <p className="text-slate-400 text-sm mt-1">{sidebarStage.sub}</p>
                    </div>
                    <button
                      onClick={() => setSidebarStageId(null)}
                      className="text-slate-600 hover:text-slate-400 transition-colors flex-shrink-0"
                    >
                      <X className="w-5 h-5" />
                    </button>
                  </div>
                </div>

                <section className="px-6 py-5 border-b border-slate-800">
                  <p className="text-xs font-bold uppercase tracking-widest text-amber-400 mb-2">What This Stage Is About</p>
                  <p className="text-slate-300 text-sm leading-relaxed">{sidebarStage.purpose}</p>
                </section>

                {sidebarStage.whatToDo.length > 0 && (
                  <section className="px-6 py-5 border-b border-slate-800">
                    <p className="text-xs font-bold uppercase tracking-widest text-amber-400 mb-3">What You Need to Do</p>
                    <ul className="space-y-2">
                      {sidebarStage.whatToDo.map((item) => (
                        <li key={item} className="flex items-start gap-3 text-sm text-slate-300">
                          <ChevronRight className="w-4 h-4 text-amber-400 flex-shrink-0 mt-0.5" />
                          {item}
                        </li>
                      ))}
                    </ul>
                  </section>
                )}

                <section className="px-6 py-5">
                  <p className="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">What Happens Next</p>
                  <p className="text-slate-300 text-sm leading-relaxed">{sidebarStage.whatHappensNext}</p>
                </section>
              </div>
            ) : sidebarStage === null ? (
              /* Empty state — guide client to pick a stage or use the main CTA */
              <div className="bg-slate-900 border border-slate-800 rounded-2xl px-6 py-10 flex flex-col items-center text-center">
                <div className="w-12 h-12 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center mb-4">
                  <Briefcase className="w-5 h-5 text-slate-500" />
                </div>
                <p className="text-slate-400 text-sm font-medium mb-1">Want to see what's ahead?</p>
                <p className="text-slate-600 text-xs max-w-xs">
                  Select any stage in the roadmap to the left to read what happens at that point in your case.
                </p>
              </div>
            ) : null}

            {/* Compact fee + case reference — always visible */}
            <div className="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
              <div className="px-5 py-4 border-b border-slate-800">
                <div className="flex items-center justify-between gap-4">
                  <div className="flex items-center gap-3 min-w-0">
                    <CreditCard className="w-4 h-4 text-slate-500 flex-shrink-0" />
                    <div className="min-w-0">
                      <p className="text-xs text-slate-500 uppercase tracking-wide font-semibold mb-1">Attorney Fees</p>
                      <div className="flex items-center gap-3 flex-wrap">
                        <div className="w-28 bg-slate-800 rounded-full h-1.5 flex-shrink-0">
                          <div className="bg-amber-400 h-1.5 rounded-full" style={{ width: `${paidPct}%` }} />
                        </div>
                        <span className="text-xs text-slate-400 whitespace-nowrap">
                          <strong className="text-white">${CASE_DATA.paidToDate.toLocaleString()}</strong> of ${CASE_DATA.totalFee.toLocaleString()} paid
                          <span className="text-slate-600 mx-1.5">·</span>
                          <span className="text-slate-400">${remaining.toLocaleString()} remaining</span>
                        </span>
                      </div>
                    </div>
                  </div>
                  <a
                    href={CASE_DATA.paymentLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="flex-shrink-0 flex items-center gap-1.5 bg-amber-400/10 hover:bg-amber-400/20 border border-amber-400/30 text-amber-400 text-xs font-bold px-3 py-1.5 rounded-lg transition-colors"
                  >
                    <CreditCard className="w-3 h-3" />
                    Pay
                  </a>
                </div>
              </div>
              <div className="px-5 py-3">
                <div className="flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs text-slate-500">
                  <span className="flex items-center gap-1.5">
                    <User className="w-3 h-3" />
                    <span className="text-slate-300 font-medium">{CASE_DATA.clientName}</span>
                  </span>
                  <span className="flex items-center gap-1.5">
                    <Briefcase className="w-3 h-3" />
                    <span>Chapter {CASE_DATA.chapter}</span>
                  </span>
                  <span className="flex items-center gap-1.5">
                    <User className="w-3 h-3" />
                    <span>{CASE_DATA.attorney}</span>
                  </span>
                  <span className="flex items-center gap-1.5">
                    <Calendar className="w-3 h-3" />
                    <span>Est. filing {CASE_DATA.estimatedFilingDate}</span>
                  </span>
                  <span className="flex items-center gap-1.5">
                    <Hash className="w-3 h-3" />
                    <span>Case # {CASE_DATA.caseNumber}</span>
                  </span>
                </div>
              </div>
            </div>

            {/* ── Credit Report Import ── */}
            <div className="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
              <button
                onClick={() => setShowCreditUploader(v => !v)}
                className="w-full px-5 py-4 flex items-center justify-between gap-3 hover:bg-slate-800/40 transition-colors"
              >
                <div className="flex items-center gap-2.5">
                  <FileText className="w-4 h-4 text-slate-400 flex-shrink-0" />
                  <div className="text-left">
                    <p className="text-sm font-bold text-white leading-none">Credit Report — Creditor Import</p>
                    <p className="text-xs text-slate-500 mt-0.5">Upload from Stretto, Experian, TransUnion, or Equifax</p>
                  </div>
                </div>
                <ChevronDown className={`w-4 h-4 text-slate-500 transition-transform ${showCreditUploader ? "rotate-180" : ""}`} />
              </button>
              {showCreditUploader && (
                <div className="border-t border-slate-800 p-5">
                  <CreditReportUploader />
                </div>
              )}
            </div>

            {/* ── Questions Panel ── */}
            <QuestionsPanel questions={questions} expanded={expandedQuestion} onToggle={setExpandedQuestion} />

          </div>
        </div>
      </div>

      {/* ── Stage 2 Detail Panel — full-screen overlay triggered by "Continue Questionnaire" ── */}
      {showStage2Panel && (
        <div className="fixed inset-0 z-50 flex items-stretch sm:items-center justify-center sm:p-6 bg-slate-950/90 backdrop-blur-sm">
          <div className="w-full sm:max-w-2xl bg-slate-900 border border-slate-700 rounded-none sm:rounded-2xl flex flex-col max-h-screen sm:max-h-[90vh] shadow-2xl">

            {/* Panel header */}
            <div className="px-6 py-5 border-b border-slate-800 bg-amber-400/5 flex items-start justify-between gap-4 flex-shrink-0">
              <div>
                <div className="flex items-center gap-2 mb-2">
                  <span className="inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wide px-2.5 py-1 rounded-full border text-amber-400 bg-amber-400/10 border-amber-400/30">
                    <Clock className="w-3 h-3" /> In Progress
                  </span>
                  <span className="text-xs text-slate-500">{stage2.date}</span>
                </div>
                <h2 className="text-xl font-bold text-white" style={{ fontFamily: "'Georgia', serif" }}>
                  Stage 2 — {stage2.label}
                </h2>
                <p className="text-slate-400 text-sm mt-1">{stage2.sub}</p>
              </div>
              <button
                onClick={() => setShowStage2Panel(false)}
                className="text-slate-500 hover:text-white transition-colors flex-shrink-0 mt-1"
              >
                <X className="w-5 h-5" />
              </button>
            </div>

            {/* Scrollable content */}
            <div className="flex-1 overflow-y-auto">

              {/* Purpose / mission */}
              <section className="px-6 py-5 border-b border-slate-800 bg-amber-400/3">
                <p className="text-xs font-bold uppercase tracking-widest text-amber-400 mb-2">Your Fresh Start Begins Here</p>
                <p className="text-slate-200 text-sm leading-relaxed">{stage2.purpose}</p>
              </section>

              {/* What we gather */}
              <section className="px-6 py-5 border-b border-slate-800">
                <p className="text-xs font-bold uppercase tracking-widest text-amber-400 mb-3">What We Are Gathering</p>
                <ul className="space-y-2.5">
                  {stage2.whatToDo.map((item) => (
                    <li key={item} className="flex items-start gap-3 text-sm text-slate-300">
                      <ChevronRight className="w-4 h-4 text-amber-400 flex-shrink-0 mt-0.5" />
                      {item}
                    </li>
                  ))}
                </ul>
              </section>

              {/* AI Tools */}
              <section className="px-6 py-5 border-b border-slate-800">
                <div className="flex items-start gap-3">
                  <Info className="w-4 h-4 text-sky-400 flex-shrink-0 mt-1" />
                  <div>
                    <p className="text-xs font-bold uppercase tracking-widest text-sky-400 mb-2">AI Tools for Faster, More Accurate Entry</p>
                    <p className="text-slate-300 text-sm leading-relaxed mb-3">{stage2.uploadDocuments}</p>
                    {daysToPayoff <= 60 ? (
                      <div className="flex items-center gap-2 bg-green-500/10 border border-green-500/25 rounded-xl px-4 py-3">
                        <CheckCircle2 className="w-4 h-4 text-green-400 flex-shrink-0" />
                        <p className="text-green-300 text-sm font-semibold">
                          Document uploads are now unlocked — you are {daysToPayoff} days from payoff.
                        </p>
                      </div>
                    ) : (
                      <div className="flex items-center gap-2 bg-slate-800 border border-slate-700 rounded-xl px-4 py-3">
                        <Clock className="w-4 h-4 text-slate-400 flex-shrink-0" />
                        <p className="text-slate-400 text-sm">
                          Document uploads unlock when you are within 60 days of payoff — currently{" "}
                          <strong className="text-white">{daysToPayoff} days</strong> away.
                        </p>
                      </div>
                    )}
                  </div>
                </div>
              </section>

              {/* Ongoing document obligations */}
              <section className="px-6 py-5 border-b border-slate-800">
                <p className="text-xs font-bold uppercase tracking-widest text-amber-400 mb-4">Ongoing Document Requirements</p>
                <div className="space-y-4">
                  <div className="flex gap-4">
                    <div className="w-8 h-8 rounded-full bg-amber-400/15 border border-amber-400/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <span className="text-amber-400 font-bold text-xs">1</span>
                    </div>
                    <div>
                      <p className="text-sm font-bold text-amber-300 mb-1">While Completing the Questionnaire</p>
                      <p className="text-slate-300 text-sm leading-relaxed">
                        All information and documents must be complete before your case can be filed.{" "}
                        <strong className="text-white">When we enter a new calendar month</strong>, updated bank statements,
                        pay stubs, and any other time-sensitive documents will be required before we can proceed.
                      </p>
                    </div>
                  </div>

                  <div className="flex gap-4">
                    <div className="w-8 h-8 rounded-full bg-amber-400/15 border border-amber-400/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <span className="text-amber-400 font-bold text-xs">2</span>
                    </div>
                    <div>
                      <p className="text-sm font-bold text-amber-300 mb-1">Before Filing — Signing Appointment</p>
                      <p className="text-slate-300 text-sm leading-relaxed">
                        Once your petition is drafted and your signing appointment is scheduled, you must provide{" "}
                        <strong className="text-white">current pay stubs and bank statements</strong> reflecting that month's
                        records. If your signing falls in a new calendar month, updated documents are required before we
                        can proceed.
                      </p>
                    </div>
                  </div>

                  <div className="flex gap-4">
                    <div className="w-8 h-8 rounded-full bg-sky-500/15 border border-sky-500/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <span className="text-sky-400 font-bold text-xs">3</span>
                    </div>
                    <div>
                      <p className="text-sm font-bold text-sky-300 mb-1">After Filing — Trustee Requirements</p>
                      <p className="text-slate-300 text-sm leading-relaxed mb-3">
                        Once your case is filed, <strong className="text-white">your obligations continue.</strong> The
                        bankruptcy trustee may request updated bank statements, tax returns, proof of income, or other
                        records at any time. You are required by law to cooperate fully and promptly.
                      </p>
                      <div className="flex items-start gap-3 bg-red-500/8 border border-red-500/25 rounded-xl px-4 py-3">
                        <AlertTriangle className="w-4 h-4 text-red-400 flex-shrink-0 mt-0.5" />
                        <p className="text-sm text-red-300 leading-relaxed">
                          Failure to comply with trustee requests can result in{" "}
                          <strong className="text-white">dismissal of your case or denial of your discharge.</strong>
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </section>

              {/* Legal accuracy notice */}
              <section className="px-6 py-5 border-b border-slate-800">
                <div className="flex items-start gap-3 bg-red-500/8 border border-red-500/25 rounded-xl px-4 py-4">
                  <AlertTriangle className="w-4 h-4 text-red-400 flex-shrink-0 mt-0.5" />
                  <div>
                    <p className="text-xs font-bold uppercase tracking-widest text-red-300 mb-2">All Information Must Be True, Accurate, and Complete</p>
                    <p className="text-slate-300 text-sm leading-relaxed mb-2">
                      Bankruptcy is a <strong className="text-white">federal legal procedure.</strong> Every answer is
                      submitted under penalty of perjury. Intentionally omitting information, concealing assets, or
                      providing false answers can result in your case being dismissed, denial of your discharge, federal
                      criminal charges, and up to 5 years in federal prison and fines up to $250,000.
                    </p>
                    <p className="text-slate-400 text-sm leading-relaxed">
                      If you are unsure whether something needs to be disclosed —{" "}
                      <strong className="text-white">include it.</strong> Let your attorney decide. It is always better
                      to over-disclose than to leave something out.
                    </p>
                  </div>
                </div>
              </section>

              {/* What happens next + encouragement */}
              <section className="px-6 py-5">
                <p className="text-xs font-bold uppercase tracking-widest text-amber-400 mb-2">What Happens When You're Done</p>
                <p className="text-slate-300 text-sm leading-relaxed mb-4">{stage2.whatHappensNext}</p>
                <div className="bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-center">
                  <p className="text-sm font-semibold text-white mb-1">Take Your Time — We Are With You Every Step</p>
                  <p className="text-xs text-slate-400 leading-relaxed">
                    There is no rush. Work at your own pace, save your progress anytime, and ask your attorney questions whenever you need to.{" "}
                    <strong className="text-amber-400">We cannot wait to get you through this.</strong>
                  </p>
                </div>
              </section>
            </div>

            {/* Sticky footer — acknowledge + launch */}
            <div className="px-6 py-5 border-t border-slate-800 bg-slate-900 flex-shrink-0">
              <label className="flex items-start gap-3 cursor-pointer mb-4 group">
                <div
                  className={`w-5 h-5 rounded border-2 flex-shrink-0 mt-0.5 flex items-center justify-center transition-all ${
                    acknowledged
                      ? "bg-amber-400 border-amber-400"
                      : "border-slate-600 group-hover:border-amber-400/60"
                  }`}
                  onClick={() => setAcknowledged((v) => !v)}
                >
                  {acknowledged && (
                    <svg className="w-3 h-3 text-slate-950" fill="currentColor" viewBox="0 0 12 12">
                      <path d="M10 3L5 8.5 2 5.5 1 6.5l4 4 6-6.5z" />
                    </svg>
                  )}
                </div>
                <span className="text-slate-300 text-sm leading-relaxed">
                  I have read and understand what is required in Stage 2. I confirm that all information I provide will be true, accurate, and complete, and I understand my ongoing document obligations before and after filing.
                </span>
              </label>

              <button
                onClick={handleLaunchQuestionnaire}
                disabled={!acknowledged}
                className={`w-full flex items-center justify-center gap-2 font-bold py-3 rounded-xl transition-all text-sm uppercase tracking-wide ${
                  acknowledged
                    ? "bg-amber-400 hover:bg-amber-300 text-slate-950 cursor-pointer"
                    : "bg-slate-800 text-slate-600 cursor-not-allowed"
                }`}
              >
                Open My Questionnaire
                <ArrowRight className="w-4 h-4" />
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
