  "allocation_ratios": {
    "description": "Use these to split bundled IRS figures across Schedule J lines. These are reasonable defaults — override with user's actual values when available.",
    "housing_and_utilities_bundle": {
      "rent_or_mortgage_1a": 0.80,
      "electric_heat_gas_3a": 0.10,
      "water_sewer_garbage_3b": 0.05,
      "phone_internet_cable_3c": 0.05
    },
    "transportation_operating_bundle": {
      "fuel_maintenance_registration_line_9": 0.70,
      "vehicle_insurance_line_12c": 0.30
    }
  },

  "schedule_j_mapping": {
    "description": "Maps Schedule J line numbers to the IRS standard source and autofill rule.",
    "1a": {
      "label": "Rent or home ownership expenses",
      "source": "housing_and_utilities[state][county][family_size]",
      "formula": "housing_bundle * allocation_ratios.housing_and_utilities_bundle.rent_or_mortgage_1a",
      "prefer_actual": true
    },
    "1b": {
      "label": "Real estate taxes",
      "source": "actual",
      "note": "Typically rolled into 1a for renters; included in IRS bundle."
    },
    "1c": {
      "label": "Property, homeowner's, or renter's insurance",
      "source": "actual",
      "note": "Included in IRS housing bundle; break out if user has separate figure."
    },
    "1d": {
      "label": "HOA or condo dues",
      "source": "actual",
      "note": "Included in IRS housing bundle."
    },
    "2": {
      "label": "Additional mortgage payments",
      "source": "actual"
    },
    "3a": {
      "label": "Electricity, heat, natural gas",
      "source": "housing_and_utilities[state][county][family_size]",
      "formula": "housing_bundle * allocation_ratios.housing_and_utilities_bundle.electric_heat_gas_3a",
      "prefer_actual": true
    },
    "3b": {
      "label": "Water, sewer, garbage collection",
      "source": "housing_and_utilities[state][county][family_size]",
      "formula": "housing_bundle * allocation_ratios.housing_and_utilities_bundle.water_sewer_garbage_3b",
      "prefer_actual": true
    },
    "3c": {
      "label": "Telephone, cell phone, internet, satellite, cable",
      "source": "housing_and_utilities[state][county][family_size]",
      "formula": "housing_bundle * allocation_ratios.housing_and_utilities_bundle.phone_internet_cable_3c",
      "prefer_actual": true
    },
    "3d": {
      "label": "Other utilities",
      "source": "actual"
    },
    "4": {
      "label": "Food and housekeeping supplies",
      "source": "national_standards.food_clothing_personal_care.by_household_size[family_size]",
      "formula": "food + housekeeping"
    },
    "5": {
      "label": "Childcare and children's education costs",
      "source": "actual",
      "note": "No IRS standard; allowed if documented as necessary."
    },
    "6": {
      "label": "Clothing, laundry, dry cleaning",
      "source": "national_standards.food_clothing_personal_care.by_household_size[family_size].apparel"
    },
    "7": {
      "label": "Personal care products and services",
      "source": "national_standards.food_clothing_personal_care.by_household_size[family_size].personal_care"
    },
    "8": {
      "label": "Medical and dental expenses",
      "source": "national_standards.out_of_pocket_healthcare.by_age",
      "formula": "sum over each person of (age < 65 ? 84 : 149)",
      "note": "Out-of-pocket only. Health insurance premiums go on line 12b."
    },
    "9": {
      "label": "Transportation (not including car payments)",
      "source": "transportation_operating_costs.by_metro_or_region[msa][num_vehicles]",
      "formula": "operating_bundle * allocation_ratios.transportation_operating_bundle.fuel_maintenance_registration_line_9",
      "note": "Use msa_county_mapping to resolve MSA; fallback to West Region."
    },
    "10": {
      "label": "Entertainment, clubs, recreation, newspapers, magazines, books",
      "source": "national_standards.food_clothing_personal_care.by_household_size[family_size].miscellaneous",
      "note": "IRS 'Miscellaneous' category covers recreation."
    },
    "11": {
      "label": "Charitable contributions and religious donations",
      "source": "actual"
    },
    "12a": {
      "label": "Life insurance",
      "source": "actual"
    },
    "12b": {
      "label": "Health insurance premiums",
      "source": "actual",
      "note": "Separate from and IN ADDITION TO line 8 out-of-pocket allowance."
    },
    "12c": {
      "label": "Vehicle insurance",
      "source": "transportation_operating_costs.by_metro_or_region[msa][num_vehicles]",
      "formula": "operating_bundle * allocation_ratios.transportation_operating_bundle.vehicle_insurance_line_12c",
      "prefer_actual": true
    },
    "12d": {
      "label": "Other insurance",
      "source": "actual"
    },
    "13": {
      "label": "Taxes (not deducted from wages or included in mortgage)",
      "source": "actual"
    },
    "14a": {
      "label": "Car payment — Vehicle 1",
      "source": "national_standards.vehicle_ownership.per_car_cap",
      "formula": "min(actual_payment_1, 662)",
      "note": "Zero if no loan/lease on vehicle 1."
    },
    "14b": {
      "label": "Car payment — Vehicle 2",
      "source": "national_standards.vehicle_ownership.per_car_cap",
      "formula": "min(actual_payment_2, 662)",
      "note": "Only if household has 2 vehicles with payments."
    },
    "14c": {
      "label": "Other installment or lease payments",
      "source": "actual"
    },
    "14d": {
      "label": "Other installment or lease payments (continued)",
      "source": "actual"
    },
    "15": {
      "label": "Alimony, maintenance, and support paid to others",
      "source": "actual",
      "note": "Court-ordered amounts."
    },
    "16": {
      "label": "Other payments of support not reported elsewhere",
      "source": "actual"
    },
    "17": {
      "label": "Other real property expenses (second home, rental, etc.)",
      "source": "actual"
    },
    "18": {
      "label": "Other — specify",
      "source": "actual"
    }
  },

  "autofill_algorithm": {
    "description": "Pseudocode for deriving Schedule J defaults from user inputs.",
    "inputs": {
      "state": "AZ | WA | CA",
      "county": "string (must match housing_and_utilities[state] key)",
      "family_size": "integer 1..N (values >4 use '5' row and add $394 per extra person)",
      "ages": "array of integers",
      "num_vehicles": "0 | 1 | 2",
      "actual_car_payment_1": "number | null",
      "actual_car_payment_2": "number | null"
    },
    "steps": [
      "1. fs_key = family_size <= 4 ? str(family_size) : '5'",
      "2. housing = housing_and_utilities[state][county][fs_key]; if family_size > 5, add 394 * (family_size - 5) (optional policy)",
      "3. ns = national_standards.food_clothing_personal_care.by_household_size[min(family_size, 4) as string]",
      "4. if family_size > 4: extra = 394 * (family_size - 4); distribute across ns components proportionally",
      "5. healthcare = sum over ages: age < 65 ? 84 : 149",
      "6. ownership_1 = (num_vehicles >= 1 && actual_car_payment_1 > 0) ? min(actual_car_payment_1, 662) : 0",
      "7. ownership_2 = (num_vehicles >= 2 && actual_car_payment_2 > 0) ? min(actual_car_payment_2, 662) : 0",
      "8. msa = msa_county_mapping[state][county] || 'West Region'",
      "9. op_key = num_vehicles >= 2 ? 'two_cars' : (num_vehicles == 1 ? 'one_car' : null)",
      "10. operating = op_key ? transportation_operating_costs.by_metro_or_region[msa][op_key] : 0",
      "11. transit = num_vehicles == 0 ? 244 : 0",
      "12. Apply allocation_ratios to split housing and operating bundles into Schedule J line items.",
      "13. For every line with prefer_actual=true, the user's actual value (if provided) overrides the derived default."
    ]
  }
}
